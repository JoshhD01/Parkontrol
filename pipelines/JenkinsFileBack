pipeline{
    agent any
    environment{
        SONAR_TOKEN="${parkontrol_SONAR_TOKEN}"
        SONAR_URL="${sonarqube_url}"
    }
    stages{
        stage('limpiar repositorio'){
            steps{
                echo 'Limpiando archivos viejos'
                sh 'rm -rf *'
            }
        }
        stage('clonar repositorio'){
            steps{
                echo 'Clonando Parkontrol'
                sh 'git clone https://github.com/JoshhD01/Parkontrol.git'

                stash name: 'repositorio', includes: '**'
            }
        }
        stage('generar coverage de pruebas backend'){
            agent {
                docker{
                    image 'node:20'
                }
            }
            steps{
                unstash 'repositorio'

                dir('Parkontrol'){
                    dir('backend'){
                        
                        sh '''
                          echo "iniciando instalacion de dependencias"
                          npm install
                        '''
                        sh '''
                          echo "ejecutando obtencion del coverage de pruebas"
                          npm run test:cov || true
                          '''
                    }
                }
                stash name: 'backend', includes: 'Parkontrol/backend/**'

            }
        }
        stage('Ejecutar sonarqube para el backend'){
              agent {
                docker {
                  image 'sonarsource/sonar-scanner-cli:latest'
                  args '--network redsonar'
                }
              }
            steps{
                unstash 'backend'

                dir('Parkontrol'){
                    dir('backend'){

                        echo "INICIO DE PROCEDIMIENTO SONARQUBE"
                        
                        sh """
                        sonar-scanner \
                          -Dsonar.host.url=${env.SONAR_URL} \
                          -Dsonar.token=${env.SONAR_TOKEN}"""
                          
                        
                    }
                }/*
                timeout(time: 5, unit: 'MINUTES') {
                script {
                    def qg = waitForQualityGate()

                    if (qg.status != 'OK') {
                    error "❌ Quality Gate falló: ${qg.status}"
                    }

                    echo "✅ Quality Gate aprobado: ${qg.status}"

                    }
                }*/
                stash name: 'backend', includes: 'Parkontrol/backend/**'
                
            }
        }

        
        stage('Compile and upload to dockerhub'){
            steps{
                unstash 'backend'
                withCredentials([usernamePassword(credentialsId: 'dockerhub', usernameVariable: 'username', passwordVariable: 'password')]) {
                    sh "echo ${username}"
                    sh """docker login -u $username -p $password"""
                    dir('Parkontrol/backend'){
                        sh "docker build -t backparkontrol:latest ."
                        sh "docker tag backparkontrol:latest ${username}/backparkontrol:latest"
                        sh "docker push ${username}/backparkontrol:latest"
                    }
                }
            }
        }

    }

}